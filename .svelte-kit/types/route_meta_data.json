{
	"/(app)": [
		"src/routes/(app)/+layout.ts",
		"src/routes/+layout.ts"
	],
	"/": [
		"src/routes/+page.ts",
		"src/routes/+layout.ts",
		"src/routes/+layout.ts"
	],
	"/(app)/certificates": [
		"src/routes/(app)/+layout.ts",
		"src/routes/+layout.ts"
	],
	"/(app)/edge": [
		"src/routes/(app)/+layout.ts",
		"src/routes/+layout.ts"
	],
	"/(app)/edge/[edgeId]/networks": [
		"src/routes/(app)/+layout.ts",
		"src/routes/+layout.ts"
	],
	"/(app)/edge/[edgeId]/networks/[networkId]/hubs": [
		"src/routes/(app)/+layout.ts",
		"src/routes/+layout.ts"
	],
	"/(app)/firmware": [
		"src/routes/(app)/+layout.ts",
		"src/routes/+layout.ts"
	],
	"/(auth)/login": [
		"src/routes/(auth)/login/+page.ts",
		"src/routes/+layout.ts"
	],
	"/(app)/notifications": [
		"src/routes/(app)/+layout.ts",
		"src/routes/+layout.ts"
	]
}